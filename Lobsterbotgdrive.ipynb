# ── Free AI Provider ──────────────────────────────────────────────────────────

async def ai_classify(content: str, filename: str) -> dict:
    """Classify file content via free provider chain. Returns zone + summary."""
    system = """You are the ClawDash LobsterBot content classifier.
Analyze file content and return ONLY valid JSON:
{
  "zone": "SPLAT|SWARM|AUDIO|AGENT|BOT|TUI|INFRA|MCP|SCM|PLAN|DEBUG|UNKNOWN",
  "relevance": 0-100,
  "summary": "one sentence what this contains",
  "interesting_patterns": ["pattern1", "pattern2"],
  "flag": "NONE|REVIEW|UNUSUAL|POSSIBLE_SENSITIVE",
  "flag_reason": "why flagged, or empty string"
}
ClawDash zones: SPLAT=gaussian splats, SWARM=PSO/GA, AUDIO=sound, AGENT=AI APIs,
BOT=Telegram, TUI=dashboards, INFRA=setup, MCP=FastMCP, SCM=memory, PLAN=architecture."""

    prompt = f"FILENAME: {filename}\n\nCONTENT (truncated):\n{content[:MAX_CONTENT_CHARS]}"

    for p in PROVIDER_CHAIN:
        api_key = os.getenv(p["key_env"]) if p["key_env"] else None
        if not api_key:
            continue
        try:
            async with httpx.AsyncClient(timeout=45) as client:
                r = await client.post(
                    f"{p['base_url']}/chat/completions",
                    headers={"Authorization": f"Bearer {api_key}",
                             "Content-Type": "application/json"},
                    json={"model": p["model"], "max_tokens": 512,
                          "messages": [{"role": "system", "content": system},
                                       {"role": "user",   "content": prompt}]}
                )
                if r.status_code == 429:
                    continue
                r.raise_for_status()
                text = r.json()["choices"][0]["message"]["content"]
                # Extract JSON
                m = re.search(r'\{[\s\S]*\}', text.replace("```json", "").replace("```", ""))
                if m:
                    return json.loads(m.group(0))
        except Exception as e:
            log(f"Provider {p['name']} error: {e}", "WARN")
            continue

    # Fallback: keyword-based classification
    return _keyword_classify(content, filename)


def _keyword_classify(content: str, filename: str) -> dict:
    """Fallback keyword-based zone classifier when no AI available."""
    text = (filename + " " + content).lower()
    scores = {zone: sum(1 for kw in kws if kw in text)
              for zone, kws in ZONE_PATTERNS.items()}
    best_zone = max(scores, key=scores.get)
    best_score = scores[best_zone]
    return {
        "zone":                best_zone if best_score > 0 else "UNKNOWN",
        "relevance":           min(best_score * 15, 100),
        "summary":             f"Keyword-classified as {best_zone} ({best_score} hits)",
        "interesting_patterns": [],
        "flag":                "NONE",
        "flag_reason":         "",
    }


async def ai_synthesize(items: list[dict]) -> str:
    """Synthesize multiple mined items into a ClawDash knowledge block."""
    if not items:
        return ""

    system = """You are the ClawDash LobsterBot knowledge synthesizer.
Given a list of mined GDrive files, generate a formatted knowledge block.
Format:
## [ZONE] [Title]
**Source**: Mined from idle GDrive
**Date**: TODAY
**Confidence**: N%

### Summary
One paragraph of what was found.

### Useful Patterns
- pattern 1
- pattern 2

### Integration Note
How this could be wired into ClawDash."""

    items_text = "\n\n".join(
        f"FILE: {item['filename']}\nZONE: {item['zone']}\nSUMMARY: {item['summary']}"
        for item in items[:10]
    )

    for p in PROVIDER_CHAIN:
        api_key = os.getenv(p["key_env"]) if p["key_env"] else None
        if not api_key:
            continue
        try:
            async with httpx.AsyncClient(timeout=60) as client:
                r = await client.post(
                    f"{p['base_url']}/chat/completions",
                    headers={"Authorization": f"Bearer {api_key}",
                             "Content-Type": "application/json"},
                    json={"model": p["model"], "max_tokens": 1024,
                          "messages": [{"role": "system", "content": system},
                                       {"role": "user",   "content": f"MINED FILES:\n{items_text}"}]}
                )
                if r.status_code == 429:
                    continue
                r.raise_for_status()
                return r.json()["choices"][0]["message"]["content"]
        except Exception:
            continue

    # Fallback: manual template
    zones = list({i["zone"] for i in items})
    return f"""## [PLAN] LobsterBot Mined Content Batch

**Source**: Idle GDrive mining run {datetime.now().strftime('%Y-%m-%d')}
**Files mined**: {len(items)}
**Zones found**: {', '.join(zones)}

### Summary
LobsterBot surfaced {len(items)} idle files during mining run.
Zones detected: {', '.join(zones)}.
AI synthesis unavailable — keyword classification used.

### Files
{chr(10).join(f"- {i['filename']}: {i['summary']}" for i in items[:20])}

### Integration Note
Review lobster_mine/raw/ for full content. High-relevance items may warrant
manual extraction into knowledge blocks for the matching zone.
"""


# ── Google Drive Auth ─────────────────────────────────────────────────────────

def get_gdrive_service():
    """Authenticate with GDrive. Opens browser for permission on first run."""
    if not GDRIVE_OK:
        raise RuntimeError("Google Drive libraries not installed.")

    creds = None

    # Colab: use Colab auth
    if IS_COLAB:
        from google.colab import auth
        auth.authenticate_user()
        from google.auth import default
        creds, _ = default()
        return build("drive", "v3", credentials=creds)

    # Load saved token
    if TOKEN_FILE.exists():
        creds = Credentials.from_authorized_user_file(str(TOKEN_FILE), SCOPES)

    # Refresh or get new token
    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            if not CREDS_FILE.exists():
                raise FileNotFoundError(
                    f"\n\n🦞 FIRST-TIME SETUP REQUIRED:\n"
                    f"1. Go to: https://console.cloud.google.com/\n"
                    f"2. Create project → Enable 'Google Drive API'\n"
                    f"3. Create OAuth2 credentials → Download as 'lobster_credentials.json'\n"
                    f"4. Place 'lobster_credentials.json' in: {Path.cwd()}\n"
                    f"5. Re-run this script — browser will open for permission\n"
                )
            flow = InstalledAppFlow.from_client_secrets_file(str(CREDS_FILE), SCOPES)
            creds = flow.run_local_server(port=0)

        # Save token
        TOKEN_FILE.write_text(creds.to_json())
        log("✓ GDrive token saved → lobster_token.json")

    return build("drive", "v3", credentials=creds)


# ── GDrive Operations ─────────────────────────────────────────────────────────

class DriveOps:
    """Low-level Google Drive operations."""

    def __init__(self, service):
        self.svc = service
        self._folder_cache: dict[str, str] = {}   # path → folder_id

    def get_or_create_folder(self, name: str, parent_id: str = None) -> str:
        """Get existing folder or create it. Returns folder_id."""
        cache_key = f"{parent_id}:{name}"
        if cache_key in self._folder_cache:
            return self._folder_cache[cache_key]

        q = f"name='{name}' and mimeType='application/vnd.google-apps.folder' and trashed=false"
        if parent_id:
            q += f" and '{parent_id}' in parents"

        results = self.svc.files().list(q=q, fields="files(id, name)").execute()
        files = results.get("files", [])

        if files:
            fid = files[0]["id"]
        else:
            meta = {
                "name": name,
                "mimeType": "application/vnd.google-apps.folder",
            }
            if parent_id:
                meta["parents"] = [parent_id]
            folder = self.svc.files().create(body=meta, fields="id").execute()
            fid = folder["id"]
            log(f"✓ Created folder: {name}")

        self._folder_cache[cache_key] = fid
        return fid

    def create_folder_path(self, path: str, root_id: str = None) -> str:
        """Create nested folder path. Returns leaf folder_id."""
        parts = path.strip("/").split("/")
        current_parent = root_id
        for part in parts:
            current_parent = self.get_or_create_folder(part, current_parent)
        return current_parent

    def upload_file(self, local_path: Path, folder_id: str,
                    overwrite: bool = True) -> str:
        """Upload a local file to GDrive folder. Returns file_id."""
        name = local_path.name
        mime = mimetypes.guess_type(str(local_path))[0] or "application/octet-stream"

        # Check for existing file
        q = f"name='{name}' and '{folder_id}' in parents and trashed=false"
        existing = self.svc.files().list(q=q, fields="files(id)").execute().get("files", [])

        media = MediaFileUpload(str(local_path), mimetype=mime)

        if existing and overwrite:
            self.svc.files().update(fileId=existing[0]["id"], media_body=media).execute()
            return existing[0]["id"]
        else:
            meta = {"name": name, "parents": [folder_id]}
            f = self.svc.files().create(body=meta, media_body=media, fields="id").execute()
            return f["id"]

    def create_text_file(self, name: str, content: str, folder_id: str) -> str:
        """Create a text file in GDrive from string content."""
        import io
        from googleapiclient.http import MediaIoBaseUpload
        meta = {"name": name, "parents": [folder_id]}
        media = MediaIoBaseUpload(io.BytesIO(content.encode()), mimetype="text/plain")
        q = f"name='{name}' and '{folder_id}' in parents and trashed=false"
        existing = self.svc.files().list(q=q, fields="files(id)").execute().get("files", [])
        if existing:
            self.svc.files().update(fileId=existing[0]["id"], media_body=media).execute()
            return existing[0]["id"]
        f = self.svc.files().create(body=meta, media_body=media, fields="id").execute()
        return f["id"]

    def list_all_files(self, modified_before: datetime = None,
                       page_size: int = 200) -> list[dict]:
        """List all files in the user's entire Drive."""
        query = "trashed=false and mimeType != 'application/vnd.google-apps.folder'"
        if modified_before:
            ts = modified_before.strftime("%Y-%m-%dT%H:%M:%S")
            query += f" and modifiedTime < '{ts}'"

        files = []
        page_token = None
        while True:
            kwargs = {
                "q": query,
                "pageSize": page_size,
                "fields": "nextPageToken, files(id, name, mimeType, modifiedTime, size, parents)",
            }
            if page_token:
                kwargs["pageToken"] = page_token

            result = self.svc.files().list(**kwargs).execute()
            files.extend(result.get("files", []))
            page_token = result.get("nextPageToken")
            if not page_token:
                break
        return files

    def download_text(self, file_id: str) -> Optional[str]:
        """Download a text/code file and return its content."""
        import io
        try:
            request = self.svc.files().get_media(fileId=file_id)
            buf = io.BytesIO()
            downloader = MediaIoBaseDownload(buf, request)
            done = False
            while not done:
                _, done = downloader.next_chunk()
            content = buf.getvalue()
            # Try UTF-8 decode
            try:
                return content.decode("utf-8")
            except UnicodeDecodeError:
                return content.decode("latin-1", errors="replace")
        except Exception as e:
            return None


# ── LobsterBot ────────────────────────────────────────────────────────────────

class LobsterBot:
